:root{--bg:#05070b;--panel:#101722;--panel2:#151e2b;--text:#f8fafc;--muted:#92a4bf;--line:rgba(255,255,255,.10);--red:#e11d2e;--green:#12c978;--yellow:#f7c948;--radius:28px;--shadow:0 30px 90px rgba(0,0,0,.36)}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:radial-gradient(circle at 80% 0%,rgba(225,29,46,.22),transparent 30%),radial-gradient(circle at 10% 10%,rgba(80,130,255,.13),transparent 35%),var(--bg);color:var(--text);font-family:Inter,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif}.app-shell{width:min(1240px,100%);margin:0 auto;padding:0 18px 90px}.topbar{height:92px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(5,7,11,.75);backdrop-filter:blur(20px);z-index:20}.brand-block{display:flex;align-items:center;gap:14px}.brand-mark{width:52px;height:52px;border-radius:16px;background:linear-gradient(145deg,#fff,#aeb8c5);color:#05070b;display:grid;place-items:center;font-weight:900;letter-spacing:-.06em}.brand-block strong{display:block;letter-spacing:.12em}.brand-block span{display:block;color:var(--muted);font-size:13px}.install-btn,.secondary,.primary{border:0;border-radius:16px;padding:14px 18px;font-weight:900;color:#fff;cursor:pointer}.install-btn,.secondary{background:#121b28;border:1px solid var(--line)}.primary{background:linear-gradient(135deg,#f22a3b,#9b0c19)}.hero-card{margin:28px 0 20px;padding:34px;border-radius:36px;display:grid;grid-template-columns:1.25fr .85fr;gap:28px;align-items:center}.glass,.panel,.mini-card{background:linear-gradient(160deg,rgba(20,29,42,.92),rgba(11,16,25,.92));border:1px solid var(--line);box-shadow:var(--shadow)}.eyebrow,.panel-head span,.mini-card span{color:#8ea7d3;text-transform:uppercase;letter-spacing:.18em;font-size:12px}.hero-copy h1{font-size:clamp(54px,9vw,106px);line-height:.78;margin:28px 0 16px;letter-spacing:-.08em;text-transform:uppercase}.hero-copy p{color:#dce7f6;max-width:650px;line-height:1.5}.actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:22px}.vehicle-status{border-radius:28px;border:1px solid var(--line);background:rgba(255,255,255,.04);padding:22px}.status-line{font-size:22px;font-weight:900;text-transform:uppercase;display:flex;align-items:center;gap:11px}.status-line span{width:12px;height:12px;border-radius:50%;background:var(--green);box-shadow:0 0 24px var(--green)}dl{margin:20px 0 0}dl div{display:flex;justify-content:space-between;gap:18px;border-bottom:1px solid var(--line);padding:14px 0}dt{color:var(--muted)}dd{margin:0;font-weight:900}.tabs{display:flex;gap:10px;overflow-x:auto;padding:4px 0 14px}.tab{border:1px solid var(--line);background:#111a27;color:#d7e4f5;border-radius:999px;padding:13px 18px;font-weight:900;cursor:pointer;white-space:nowrap}.tab.active{background:#fff;color:#07101b}.page{display:none}.page.active{display:block}.quick-grid,.health-grid,.schedule-grid,.doc-grid{display:grid;gap:16px}.quick-grid{grid-template-columns:repeat(4,1fr)}.health-grid{grid-template-columns:repeat(3,1fr)}.schedule-grid,.doc-grid{grid-template-columns:repeat(4,1fr)}.mini-card,.panel{border-radius:var(--radius);padding:22px}.mini-card strong{display:block;font-size:28px;margin:10px 0 4px}.mini-card small{color:var(--muted)}.panel{margin-top:20px}.panel-head{margin-bottom:18px}.panel-head b{display:block;font-size:28px;margin-top:8px}.health-card{border:1px solid var(--line);background:rgba(255,255,255,.035);border-radius:22px;padding:18px;display:grid;gap:6px}.health-card i{width:12px;height:12px;border-radius:50%;background:var(--green);box-shadow:0 0 18px var(--green)}.health-card.unknown i{background:var(--yellow);box-shadow:0 0 18px var(--yellow)}.health-card strong{font-size:20px}.health-card span,.spec-list span,.service-card span,.schedule-grid small,.doc-grid span{color:var(--muted)}.split-panel,.qr-panel{display:grid;grid-template-columns:1fr .7fr;gap:22px}.spec-list{list-style:none;padding:0;margin:0}.spec-list li{display:flex;justify-content:space-between;gap:22px;border-bottom:1px solid var(--line);padding:15px 0}.spec-list li:last-child{border-bottom:0}.spec-list.compact b{max-width:58%;text-align:right}.lifetime-card{border-radius:24px;background:linear-gradient(160deg,rgba(225,29,46,.18),rgba(255,255,255,.04));border:1px solid var(--line);padding:24px}.lifetime-card span{color:var(--muted);text-transform:uppercase;letter-spacing:.14em;font-size:12px}.lifetime-card strong{display:block;font-size:42px;margin:14px 0}.progress{height:7px;background:rgba(255,255,255,.1);border-radius:999px;overflow:hidden;margin:22px 0}.progress em{display:block;height:100%;background:var(--green)}.service-card{display:grid;grid-template-columns:86px 1fr;gap:18px;border:1px solid var(--line);border-radius:24px;padding:20px;background:rgba(255,255,255,.035)}.service-no{height:72px;border-radius:20px;background:#fff;color:#06101b;display:grid;place-items:center;font-size:28px;font-weight:900}.service-card h3{margin:8px 0;font-size:26px}.chips{display:flex;gap:8px;flex-wrap:wrap}.chips i{font-style:normal;border:1px solid rgba(18,201,120,.35);color:#96f5c5;background:rgba(18,201,120,.08);border-radius:999px;padding:7px 10px;font-weight:800;font-size:12px}.schedule-grid div,.doc-grid div{border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.035);padding:18px}.schedule-grid span{display:block;color:var(--muted);text-transform:uppercase;letter-spacing:.12em;font-size:11px}.schedule-grid b{display:block;font-size:21px;margin:10px 0}.timeline{display:grid;gap:14px;border-left:1px solid var(--line);padding-left:20px}.timeline article{position:relative;border:1px solid var(--line);border-radius:22px;background:rgba(255,255,255,.035);padding:18px}.timeline article:before{content:"";position:absolute;left:-27px;top:23px;width:13px;height:13px;border-radius:50%;background:var(--green);box-shadow:0 0 18px var(--green)}.timeline time{color:#8ea7d3;letter-spacing:.12em;text-transform:uppercase;font-size:12px}.timeline b{display:block;font-size:22px;margin:8px 0}.timeline p{margin:0;color:var(--muted)}.doc-grid strong{display:block;font-size:20px;margin-bottom:8px}.qr-card{border-radius:28px;background:#f4f6f8;color:#08111f;border:5px solid #08111f;padding:20px;text-align:center}.qr-card span{display:block;letter-spacing:.16em;font-size:12px}.qr-card strong{display:block;font-size:26px;margin:6px 0 12px}.qr-card img{width:100%;max-width:320px;border-radius:16px}.link{display:inline-block;text-decoration:none;margin-top:10px}@media(max-width:900px){.hero-card,.split-panel,.qr-panel{grid-template-columns:1fr}.quick-grid,.health-grid,.schedule-grid,.doc-grid{grid-template-columns:1fr 1fr}.hero-copy h1{font-size:58px}.topbar{height:78px}.install-btn{display:none}}@media(max-width:560px){.app-shell{padding:0 12px 80px}.hero-card{padding:24px;border-radius:28px}.quick-grid,.health-grid,.schedule-grid,.doc-grid{grid-template-columns:1fr}.hero-copy h1{font-size:48px}.spec-list li{display:block}.spec-list b{display:block!important;max-width:none!important;text-align:left!important;margin-top:6px}.service-card{grid-template-columns:1fr}.brand-block span{display:none}}@media print{.topbar,.tabs,.actions{display:none}.app-shell{padding:0}.page{display:block}.hero-card,.panel,.mini-card{box-shadow:none;background:#fff;color:#111;border:1px solid #ddd}.hero-copy p,.mini-card small,.health-card span,.timeline p,.spec-list span{color:#555}}
