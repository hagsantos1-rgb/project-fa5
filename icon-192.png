const CACHE='project-fa5-v1';
const ASSETS=['./','./index.html','./manifest.webmanifest','./assets/css/style.css','./assets/js/app.js','./assets/icons/icon-192.png','./assets/icons/icon-512.png','./assets/img/qr_project_fa5.png','./assets/img/cartao_qr_project_fa5_github.png'];
self.addEventListener('install',e=>e.waitUntil(caches.open(CACHE).then(c=>c.addAll(ASSETS))));
self.addEventListener('activate',e=>e.waitUntil(caches.keys().then(keys=>Promise.all(keys.filter(k=>k!==CACHE).map(k=>caches.delete(k))))));
self.addEventListener('fetch',e=>e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request))));
